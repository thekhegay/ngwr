{
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node10",
    "target": "ES2022",
    "outDir": "../../../dist/lib/schematics",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "declaration": false,
    "sourceMap": false,
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["**/*.spec.ts"]
}
