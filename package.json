{
  "name": "ngwr-workspace",
  "version": "0.0.0-NOT-USED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ng serve --o",
    "test": "ng test",
    "lint": "ng lint && eslint scripts && pnpm lint:styles",
    "lint:styles": "stylelint \"projects/**/*.scss\"",
    "build:lib": "ng build lib && tsx scripts/copy-dist-assets.ts && tsx scripts/build-schematics.ts",
    "build:showcase": "ng build showcase",
    "icons:sets": "node scripts/build-icon-sets.mjs",
    "postinstall": "node scripts/build-icon-sets.mjs",
    "release:prepare": "tsx scripts/release-prepare.ts",
    "release:body": "tsx scripts/release-body.ts",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "commit-msg": "npx --no-install commitlint --edit $1"
  },
  "engines": {
    "node": "^24.15.0 || >=26.0.0",
    "pnpm": "^11.5.0"
  },
  "packageManager": "pnpm@11.5.1",
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "ngx-mask": "^21.0.1",
    "rxjs": "~7.8.2",
    "shiki": "^4.2.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "^22.0.0",
    "@angular-devkit/schematics": "^22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@phosphor-icons/core": "^2.1.1",
    "@schematics/angular": "^22.0.0",
    "@tabler/icons": "^3.44.0",
    "@types/conventional-changelog": "^6.0.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.12.4",
    "@types/semver": "^7.7.1",
    "angular-eslint": "^21.4.0",
    "bootstrap-icons": "^1.13.1",
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "date-fns": "^4.4.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.6",
    "feather-icons": "^4.29.2",
    "heroicons": "^2.2.0",
    "iconoir": "^7.11.0",
    "lucide": "^1.17.0",
    "luxon": "^3.7.2",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.3",
    "semver": "^7.8.2",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.12.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.2.0",
    "svgo": "^4.0.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1"
  }
}
